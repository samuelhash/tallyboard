# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
# Both values are intentionally public (protected by Row Level Security).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── PostHog ───────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → Project API Key
# Analytics are silently disabled when this key is absent (safe for local dev).

NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-api-key-here

# ── Optional ──────────────────────────────────────────────────────────────────
# Override the canonical site URL used in sitemap.xml and OG tags.
# Defaults to https://tallyboard.io when unset.

# NEXT_PUBLIC_SITE_URL=https://your-custom-domain.com
